{
  "expo": {
    "name": "valmak-app",
    "slug": "valmak-app",
    "version": "1.0.0",
    "scheme": "valmak",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "bundleIdentifier": "com.valmak.app",
      "supportsTablet": true
    },
    "android": {
      "package": "com.valmak.app",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-status-bar",
      "expo-font",
      "expo-sharing",
      "expo-notifications",
      "@react-native-community/datetimepicker",
      [
        "expo-image-picker",
        {
          "photosPermission": "Valmak necesita acceso a tu galería para subir fotos.",
          "cameraPermission": "Valmak necesita la cámara para tomar fotos de perfil."
        }
      ],
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "e5ec584b-fccb-4ddc-acfe-5b25973347cf"
      }
    }
  }
}
